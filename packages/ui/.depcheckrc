ignores: [
    # Dependencies that depcheck thinks are unused but are actually used / lock explicit versions
    '@tamagui/animations-react-native',
    '@tamagui/font-inter',
    '@tamagui/theme-base',
    'jest-presets',
    'typescript',
    '@typescript/native-preview',
    'oxlint',
    ## Internal packages / workspaces
    'ui',
    # peer dep of @tamagui/animations-moti
    'moti',
    # used in package.json
    'esbuild-register',
  ]
ignore-patterns: [
    'src/components/icons',
    'src/components/logos',
  ]
