+// PATCH (universe): reject possibly-undefined values in the t() options object.
+// Maps any property whose type includes `undefined` to `never`, so the passed
+// object stops being assignable. Resource-type-independent (works even though this
+// repo erases resources to Record<string, string>). Replaces the i18n rule in
+// config/oxlint-plugins/typeaware-custom.ts. Applied to the t() options arg below.
+type $NoUndefinedValues<T> = {
+  // `0 extends 1 & T[K]` is true only when T[K] is `any` — pass `any` through so
+  // untyped values aren't flagged (parity with the old TypeFlags.Undefined check).
+  [K in keyof T]-?: 0 extends 1 & T[K] ? T[K] : undefined extends T[K] ? never : T[K];
+};
+
