@@ -4,6 +4,7 @@
 # LICENSE file in the root directory of this source tree.
 
 require "json"
+require "pathname"
 require_relative "./hermes-utils.rb"
 
 begin
@@ -92,8 +93,14 @@ Pod::Spec.new do |spec|
         "require.resolve(\"hermes-compiler\", {paths: [\"#{react_native_path}\"]})", __dir__]).strip
       )
 
+      # Use a path relative to PODS_ROOT so the absolute home-directory path isn't baked into the
