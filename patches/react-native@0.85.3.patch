+      # See https://github.com/facebook/react-native/issues/54891
+      hermesc_absolute_path = "#{hermes_compiler_path}/hermesc/osx-bin/hermesc"
+      relative_hermesc_path = Pathname.new(hermesc_absolute_path).relative_path_from(Pod::Config.instance.sandbox_root)
