     react_native_assert(&childNode.yogaNode_ == childYogaNode);
 
     if (childYogaNode->getHasNewLayout()) {
+      // A child yoga node owned by another tree generation is shared, not
+      // ours to consume: reading it here (and clearing hasNewLayout below)
+      // steals the layout notification from the owning tree, which then never
+      // applies metrics — views render invisible while React state stays
+      // mounted. Skip it and let the owning generation deliver the layout.
+      // Upstream: https://github.com/facebook/react-native/issues/52349
+      if (YGNodeGetOwner(childYogaNode) != &yogaNode_) {
+        continue;
+      }
+
       childYogaNode->setHasNewLayout(false);
 
       // Reading data from a dirtied node does not make sense.
